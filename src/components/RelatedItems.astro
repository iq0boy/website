---
import { localePath } from '../lib/i18n';
import type { Lang } from '../lib/i18n';

interface Item {
  href: string;
  title: string;
  excerpt: string;
  meta: string;
  color?: string;
}

interface Props {
  lang: Lang;
  label: string;
  items: Item[];
}

const { label, items } = Astro.props;
---
{items.length > 0 && (
  <section style="border-top: 1px solid var(--border); padding-top: 48px;">
    <p style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 32px;">
      {label}
    </p>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px;">
      {items.map(item => (
        <a href={item.href} class="related-card" style="display: block; padding: 24px; border: 1px solid var(--border); border-radius: 4px; text-decoration: none; color: inherit; transition: border-color 0.3s, transform 0.3s;">
          {item.color && (
            <div style={`width: 32px; height: 3px; background: ${item.color}; margin-bottom: 16px;`}></div>
          )}
          <p style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px;">
            {item.meta}
          </p>
          <h3 style="font-family: var(--font-display); font-size: 1.25rem; line-height: 1.2; margin-bottom: 10px; color: var(--text-primary);">
            {item.title}
          </h3>
          <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            {item.excerpt}
          </p>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-card:hover {
    border-color: var(--accent) !important;
    transform: translateY(-2px);
  }
</style>
