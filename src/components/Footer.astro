---
---
<footer style="border-top: 1px solid var(--border); padding: 60px 0 40px;">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-bottom: 60px;">
      <div>
        <div style="font-family: var(--font-display); font-size: 1.8rem; margin-bottom: 16px;">
          Joseph<span style="color: var(--accent);">.</span>
        </div>
        <p class="body-lg" style="font-size: 0.9rem; max-width: 280px;">
          Full-stack developer crafting digital experiences that matter.
        </p>
      </div>
      <div>
        <p class="label" style="margin-bottom: 16px;">Navigation</p>
        <a href="/" class="footer-link">Home</a>
        <a href="/services" class="footer-link">Services</a>
        <a href="/portfolio" class="footer-link">Portfolio</a>
        <a href="/blog" class="footer-link">Blog</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
      <div>
        <p class="label" style="margin-bottom: 16px;">Connect</p>
        <a href="#" class="footer-link">GitHub</a>
        <a href="#" class="footer-link">LinkedIn</a>
        <a href="#" class="footer-link">Twitter / X</a>
        <a href="#" class="footer-link">Dribbble</a>
      </div>
      <div>
        <p class="label" style="margin-bottom: 16px;">Get in touch</p>
        <a href="mailto:hello@josephpire.dev" style="color: var(--accent); font-size: 0.9rem;">hello@josephpire.dev</a>
      </div>
    </div>
    <div class="divider" style="margin-bottom: 30px;"></div>
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
      <p style="color: var(--text-muted); font-size: 0.8rem;">© 2026 Joseph Pire. All rights reserved.</p>
      <p style="font-family: var(--font-mono); color: var(--text-muted); font-size: 0.7rem;">Built with passion &amp; clean code</p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    display: block;
    color: var(--text-secondary);
    margin-bottom: 10px;
    font-size: 0.9rem;
    transition: color 0.3s;
  }
  .footer-link:hover {
    color: var(--accent);
  }
</style>
