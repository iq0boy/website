---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav';
import FooterI18n from '../components/FooterI18n';
import SearchModal from '../components/SearchModal';
import ShortcutsOverlay from '../components/ShortcutsOverlay';
import '../styles/global.css';
import type { Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  lang?: Lang;
  ogImage?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  // Locales for which this exact page is available. Defaults to all three.
  // When a page only exists in some locales, pass the subset so hreflang
  // alternates don't point at 404s.
  availableLocales?: Lang[];
  // Canonical override — if this page is a fallback (e.g. EN slug serving FR
  // content because the translation isn't done yet), set canonical to the
  // original-locale URL.
  canonicalOverride?: string;
}

const {
  title,
  description = 'Joseph Pire — Full-Stack Developer & Designer based in Belgium. Building elegant, high-performance web solutions.',
  currentPage = 'home',
  lang = 'fr',
  ogImage,
  type = 'website',
  pubDate,
  structuredData,
  availableLocales = ['fr', 'en', 'nl'],
  canonicalOverride,
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.origin : 'https://josephpire.dev';
const pathname = Astro.url.pathname;

// Strip lang prefix to get locale-neutral base path
const basePath = lang !== 'fr'
  ? pathname.replace(new RegExp(`^\\/${lang}(?=/|$)`), '') || '/'
  : pathname;

const canonicalUrl = canonicalOverride ?? `${siteUrl}${pathname}`;
const enUrl = `${siteUrl}${basePath === '/' ? '/en' : `/en${basePath}`}`;
const nlUrl = `${siteUrl}${basePath === '/' ? '/nl' : `/nl${basePath}`}`;
const frUrl = `${siteUrl}${basePath}`;
const has = (l: Lang) => availableLocales.includes(l);

// Default OG image — absolute URL required by the spec
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og.png`;

const safeJson = (obj: Record<string, unknown>) =>
  JSON.stringify(obj)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');

const userSchemas: Record<string, unknown>[] = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];

// Site-wide WebSite schema — present on every page, enables sitelinks search box
const websiteLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: siteUrl,
  name: 'Joseph Pire',
  inLanguage: ['fr-BE', 'en', 'nl-BE'],
  publisher: { '@type': 'Person', name: 'Joseph Pire', url: siteUrl },
};

const schemas = [websiteLd, ...userSchemas];
---
<!DOCTYPE html>
<html lang={lang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Joseph Pire" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
  <link rel="canonical" href={canonicalUrl} />
  {has('fr') && <link rel="alternate" hreflang="fr" href={frUrl} />}
  {has('en') && <link rel="alternate" hreflang="en" href={enUrl} />}
  {has('nl') && <link rel="alternate" hreflang="nl" href={nlUrl} />}
  {has('fr') && <link rel="alternate" hreflang="x-default" href={frUrl} />}
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Joseph Pire — Blog" href={lang === 'fr' ? '/rss.xml' : `/${lang}/rss.xml`} />
  <meta property="og:site_name" content="Joseph Pire" />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {type === 'article' && pubDate && (
    <meta property="article:published_time" content={pubDate.toISOString()} />
  )}
  {type === 'article' && (
    <meta property="article:author" content="https://josephpire.dev" />
  )}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  {schemas.map(schema => (
    <script type="application/ld+json" set:html={safeJson(schema)} />
  ))}
  <ClientRouter fallback="swap" />
  <slot name="head" />
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('jp-theme')
        || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <div class="noise-overlay"></div>
  <Nav currentPage={currentPage} lang={lang} client:load transition:persist />
  <slot />
  <SearchModal lang={lang} client:idle transition:persist />
  <ShortcutsOverlay lang={lang} client:idle transition:persist />
  <FooterI18n lang={lang} client:visible />
  {import.meta.env.PROD && (
    <script is:inline>
      // Registered in production only, so dev assets are never cached.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
  )}
</body>
</html>
