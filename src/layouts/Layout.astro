---
import Nav from '../components/Nav';
import ChatWidget from '../components/ChatWidget';
import FooterI18n from '../components/FooterI18n';
import '../styles/global.css';
import type { Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  lang?: Lang;
  ogImage?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Joseph Pire — Full-Stack Developer & Designer based in Belgium. Building elegant, high-performance web solutions.',
  currentPage = 'home',
  lang = 'fr',
  ogImage,
  type = 'website',
  pubDate,
  structuredData,
} = Astro.props;

const siteUrl = 'https://josephpire.dev';
const pathname = Astro.url.pathname;

// Strip lang prefix to get locale-neutral base path
const basePath = lang !== 'fr'
  ? pathname.replace(new RegExp(`^\\/${lang}(?=/|$)`), '') || '/'
  : pathname;

const canonicalUrl = `${siteUrl}${pathname}`;
const enUrl = `${siteUrl}${basePath === '/' ? '/en' : `/en${basePath}`}`;
const nlUrl = `${siteUrl}${basePath === '/' ? '/nl' : `/nl${basePath}`}`;
const frUrl = `${siteUrl}${basePath}`;

// Default OG image — absolute URL required by the spec
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og.png`;

const safeJson = (obj: Record<string, unknown>) =>
  JSON.stringify(obj)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');

const schemas: Record<string, unknown>[] = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];
---
<!DOCTYPE html>
<html lang={lang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Joseph Pire" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="fr" href={frUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="nl" href={nlUrl} />
  <link rel="alternate" hreflang="x-default" href={frUrl} />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <meta property="og:site_name" content="Joseph Pire" />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {type === 'article' && pubDate && (
    <meta property="article:published_time" content={pubDate.toISOString()} />
  )}
  {type === 'article' && (
    <meta property="article:author" content="https://josephpire.dev" />
  )}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  {schemas.map(schema => (
    <script type="application/ld+json" set:html={safeJson(schema)} />
  ))}
  <slot name="head" />
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('jp-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <div class="noise-overlay"></div>
  <Nav currentPage={currentPage} lang={lang} client:load />
  <slot />
  <FooterI18n lang={lang} client:visible />
  <ChatWidget lang={lang} client:idle />
</body>
</html>
