---
import Layout from '../layouts/Layout.astro';

const lang = 'fr';
---
<Layout
  title="404 — Page introuvable | Joseph Pire"
  description="Cette page n'existe pas ou a été déplacée."
  currentPage="404"
  lang={lang}
>
  <section
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 120px 24px 60px; text-align: center;"
  >
    <div style="max-width: 640px;">
      <p
        style="font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 24px;"
      >
        Error 404
      </p>
      <h1
        style="font-family: var(--font-display); font-size: clamp(3rem, 10vw, 6rem); line-height: 1; margin-bottom: 32px;"
      >
        Cette page n'existe<br />
        <span style="font-style: italic; color: var(--accent);">pas vraiment.</span>
      </h1>
      <p
        style="color: var(--text-secondary); font-size: 1.05rem; line-height: 1.7; margin-bottom: 48px; max-width: 480px; margin-left: auto; margin-right: auto;"
      >
        Le lien est peut-être périmé, ou j'ai déplacé quelque chose sans laisser de
        redirection. Cherchez ce que vous vouliez, ou rejoignez une destination qui
        existe vraiment :
      </p>
      <button
        id="search-404"
        type="button"
        class="btn-outline"
        style="font-size: 0.9rem; padding: 14px 28px; margin-bottom: 32px; display: inline-flex; align-items: center; gap: 10px; cursor: pointer;"
        aria-label="Rechercher sur le site"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        Rechercher sur le site
        <kbd
          style="font-family: var(--font-mono); font-size: 0.7rem; padding: 2px 6px; border: 1px solid var(--border); border-radius: 4px; color: var(--text-muted);"
        >⌘K</kbd>
      </button>
      <div
        style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;"
      >
        <a href="/" class="btn-outline" style="font-size: 0.85rem; padding: 12px 24px;">Accueil</a>
        <a
          href="/portfolio"
          class="btn-outline"
          style="font-size: 0.85rem; padding: 12px 24px;"
        >Projets</a>
        <a href="/blog" class="btn-outline" style="font-size: 0.85rem; padding: 12px 24px;">Blog</a>
        <a
          href="/contact"
          class="btn-outline"
          style="font-size: 0.85rem; padding: 12px 24px;"
        >Contact</a>
      </div>
      <p
        style="margin-top: 64px; font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em;"
      >
        EN · <a href="/en/" style="color: var(--accent);">English version</a> ·
        NL · <a href="/nl/" style="color: var(--accent);">Nederlandse versie</a>
      </p>
    </div>
  </section>
  <script is:inline>
    // Reuse the globally-mounted SearchModal (⌘K) so a wrong URL can still recover.
    (function () {
      var btn = document.getElementById('search-404');
      if (!btn) return;
      btn.addEventListener('click', function open() {
        if (window.__jpOpenSearch) window.__jpOpenSearch();
        else setTimeout(open, 50); // modal hydrates client:idle; retry until ready
      });
    })();
  </script>
</Layout>
