---
import Layout from '../../layouts/Layout.astro';
import LegalPage from '../../components/LegalPage.astro';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { lang: 'en' as Lang } },
    { params: { lang: 'nl' }, props: { lang: 'nl' as Lang } },
  ];
}

const { lang } = Astro.props;
const titles: Record<Lang, string> = {
  fr: 'Conditions générales — Joseph Pire',
  en: 'Terms of service — Joseph Pire',
  nl: 'Algemene voorwaarden — Joseph Pire',
};
const descs: Record<Lang, string> = {
  fr: '',
  en: 'General terms of service of Joseph Pire — freelance full-stack developer and designer.',
  nl: 'Algemene voorwaarden van Joseph Pire — freelance full-stack developer en designer.',
};
---
<Layout title={titles[lang]} description={descs[lang]} currentPage="terms" lang={lang}>
  <LegalPage lang={lang} slug="terms" />
</Layout>
