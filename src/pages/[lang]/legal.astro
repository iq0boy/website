---
import Layout from '../../layouts/Layout.astro';
import LegalPage from '../../components/LegalPage.astro';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { lang: 'en' as Lang } },
    { params: { lang: 'nl' }, props: { lang: 'nl' as Lang } },
  ];
}

const { lang } = Astro.props;
const titles: Record<Lang, string> = {
  fr: 'Mentions légales — Joseph Pire',
  en: 'Legal notice — Joseph Pire',
  nl: 'Wettelijke vermelding — Joseph Pire',
};
const descs: Record<Lang, string> = {
  fr: '',
  en: 'Legal information about the josephpire.dev site.',
  nl: 'Wettelijke informatie over josephpire.dev.',
};
---
<Layout title={titles[lang]} description={descs[lang]} currentPage="legal" lang={lang}>
  <LegalPage lang={lang} slug="legal" />
</Layout>
