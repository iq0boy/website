---
import Layout from '../../layouts/Layout.astro';
import ServicesContent from '../../components/pages/ServicesContent';
import { buildFaqLd } from '../../lib/faq';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { lang: 'en' as Lang } },
    { params: { lang: 'nl' }, props: { lang: 'nl' as Lang } },
  ];
}

const { lang } = Astro.props;

const titles: Record<Lang, string> = {
  fr: 'Services — Joseph Pire',
  en: 'Services — Joseph Pire',
  nl: 'Diensten — Joseph Pire',
};
const descs: Record<Lang, string> = {
  fr: '',
  en: 'Belgium-based freelance developer. End-to-end digital solutions: React/Node.js web development, UI/UX design, AI integration, consulting and mentoring.',
  nl: 'Freelance developer gevestigd in België. End-to-end digitale oplossingen: webontwikkeling met React/Node.js, UI/UX design, AI-integratie en consulting.',
};
---

<Layout title={titles[lang]} description={descs[lang]} currentPage="services" lang={lang} structuredData={buildFaqLd(lang)}>
  <ServicesContent lang={lang} client:visible />
</Layout>
