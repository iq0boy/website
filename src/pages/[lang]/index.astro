---
import Layout from '../../layouts/Layout.astro';
import HomeContent from '../../components/pages/HomeContent';
import { getCollection } from 'astro:content';
import { coverFor } from '../../lib/projectCovers';
import { FEATURED_PROJECTS } from '../../lib/profile';
import type { Lang } from '../../lib/i18n';
import GitHubActivity from '../../components/GitHubActivity.astro';
import ClientLogos from '../../components/ClientLogos';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { lang: 'en' as Lang } },
    { params: { lang: 'nl' }, props: { lang: 'nl' as Lang } },
  ];
}

const { lang } = Astro.props;

const allProjects = await getCollection('projects', ({ id }) => id.startsWith(lang + '/'));
const projectBySlug = new Map(
  allProjects.map(p => [p.id.split('/').slice(1).join('/').replace(/\.md$/, ''), p]),
);
const featuredProjects = await Promise.all(
  FEATURED_PROJECTS.map(slug => projectBySlug.get(slug))
    .filter(p => p !== undefined)
    .map(async p => {
      const slug = p!.id.split('/').slice(1).join('/').replace(/\.md$/, '');
      return {
        slug,
        title: p!.data.title,
        excerpt: p!.data.excerpt,
        category: p!.data.category,
        tags: p!.data.tags,
        year: p!.data.year,
        color: p!.data.color,
        image: (await coverFor(slug)) ?? undefined,
      };
    }),
);

const titles: Record<Lang, string> = {
  fr: 'Joseph Pire — Développeur Full-Stack & Designer',
  en: 'Joseph Pire — Full-Stack Developer & Designer',
  nl: 'Joseph Pire — Full-Stack Developer & Designer',
};
const descs: Record<Lang, string> = {
  fr: 'Joseph Pire est un développeur full-stack et designer basé en Belgique.',
  en: 'Joseph Pire is a full-stack developer and designer based in Belgium, building elegant high-performance web solutions.',
  nl: 'Joseph Pire is een full-stack developer en designer gevestigd in België, die elegante weboplossingen bouwt.',
};
const jobTitles: Record<Lang, string> = {
  fr: 'Développeur Full-Stack & Designer',
  en: 'Full-Stack Developer & Designer',
  nl: 'Full-Stack Developer & Designer',
};
---

<Layout
  title={titles[lang]}
  description={descs[lang]}
  currentPage="home"
  lang={lang}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Joseph Pire",
    "url": "https://josephpire.dev",
    "email": "josephpire.dev@gmail.com",
    "jobTitle": jobTitles[lang],
    "address": { "@type": "PostalAddress", "addressCountry": "BE" },
    "sameAs": [
      "https://github.com/iq0boy",
      // Ajouter ici LinkedIn, Twitter/X, Dribbble...
    ],
  }}
>
  <HomeContent lang={lang} featuredProjects={featuredProjects} client:load />
  <ClientLogos lang={lang} client:visible />
  <GitHubActivity lang={lang} />
</Layout>
