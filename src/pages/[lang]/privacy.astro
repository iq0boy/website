---
import Layout from '../../layouts/Layout.astro';
import LegalPage from '../../components/LegalPage.astro';
import type { Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { lang: 'en' as Lang } },
    { params: { lang: 'nl' }, props: { lang: 'nl' as Lang } },
  ];
}

const { lang } = Astro.props;
const titles: Record<Lang, string> = {
  fr: 'Politique de confidentialité — Joseph Pire',
  en: 'Privacy policy — Joseph Pire',
  nl: 'Privacybeleid — Joseph Pire',
};
const descs: Record<Lang, string> = {
  fr: '',
  en: 'How Joseph Pire collects, uses, and protects your personal data.',
  nl: 'Hoe Joseph Pire uw persoonsgegevens verzamelt, gebruikt en beschermt.',
};
---
<Layout title={titles[lang]} description={descs[lang]} currentPage="privacy" lang={lang}>
  <LegalPage lang={lang} slug="privacy" />
</Layout>
